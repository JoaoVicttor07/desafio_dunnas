# ==========================================
# AMBIENTE LOCAL (DESENVOLVIMENTO)
# Copie este arquivo para .env e ajuste os valores.
# ==========================================

# 1) Ambiente Rails
RAILS_ENV=development

# 2) Chave secreta da aplicacao (gere com: bin/rails secret)
SECRET_KEY_BASE=gerar_com_bin_rails_secret

# 3) Banco de dados PostgreSQL (container do docker compose local)
POSTGRES_HOST=db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=trocar_por_senha_local
POSTGRES_DB=desafio_dunnas_development

# 4) Usuario administrador inicial (seed)
ADMIN_EMAIL=admin@condominio.local
ADMIN_PASSWORD=trocar_por_senha_admin_local
