# ==========================================
# AMBIENTE DE PRODUCAO (SERVIDOR)
# Copie este arquivo para .env.production e ajuste os valores.
# ==========================================

# 1) Imagem que sera baixada do Docker Hub
# Formato: usuario_dockerhub/nome_imagem:tag
APP_IMAGE=seu_usuario_dockerhub/imagem:1.0.1

# 2) Porta publicada no servidor fisico
APP_PORT=3000

# 3) Seguranca do Rails
# RAILS_MASTER_KEY: conteudo do arquivo config/master.key
RAILS_MASTER_KEY=colar_master_key_aqui

# SECRET_KEY_BASE: gere com `bin/rails secret` (ou `docker compose run --rm web bin/rails secret`)
SECRET_KEY_BASE=gerar_e_colar_secret_key_base

# 4) Ajustes de runtime da aplicacao
RAILS_LOG_LEVEL=info
RAILS_MAX_THREADS=5
REQUIRE_MASTER_KEY=true
RAILS_SERVE_STATIC_FILES=true

# 5) Armazenamento de anexos
# local = salva em volume Docker (mais simples para inicio)
ACTIVE_STORAGE_SERVICE=local

# 6) HTTPS / proxy reverso
# Use true quando estiver atras de Nginx/Traefik com HTTPS configurado.
FORCE_SSL=true
ASSUME_SSL=true

# 7) Banco de dados PostgreSQL de producao
POSTGRES_HOST=db
POSTGRES_DB=desafio_dunnas_production
POSTGRES_USER=postgres
POSTGRES_PASSWORD=trocar_por_senha_forte_do_banco

# 8) Administrador inicial (seed)
ADMIN_EMAIL=admin@seucondominio.com
ADMIN_PASSWORD=trocar_por_senha_admin_forte
