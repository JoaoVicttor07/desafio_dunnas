<% provide(:title, "Visualizar Chamado | Condomínio Dunnas") %>
<% provide(:page_heading, "Detalhes do Chamado") %>

<div class="max-w-4xl mx-auto mb-10 mt-6">
  
  <div class="flex justify-between items-center mb-6">
    <div>
      <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">
        Chamado #<%= @ticket.id.to_s.rjust(4, '0') %>
      </h1>
      <p class="text-gray-500 mt-1 font-medium"><%= @ticket.ticket_type.title %></p>
    </div>
    <div class="text-right">
      <span class="mb-2 inline-flex rounded-full bg-violet-100 px-4 py-2 text-sm font-bold leading-5 text-violet-800">
        <%= @ticket.ticket_status.name %>
      </span>
      <p class="text-sm text-gray-500 font-semibold">
        <%= @ticket.unit.block.identification %> - Apartamento <%= @ticket.unit.identifier %>
      </p>
    </div>
  </div>

  <div class="bg-white shadow overflow-hidden sm:rounded-lg mb-8 border border-gray-200">
    <div class="px-4 py-5 sm:px-6 bg-gray-50 border-b border-gray-200 flex justify-between">
      <h3 class="text-lg leading-6 font-bold text-gray-900">Descrição do Problema</h3>
      <span class="text-sm text-gray-500">Aberto por: <%= @ticket.user.name %></span>
    </div>
    <div class="px-4 py-5 sm:p-6 text-gray-700 whitespace-pre-wrap"><%= @ticket.description %></div>
  </div>

  <% if @ticket.attachments.attached? %>
    <div class="bg-white shadow-sm border border-gray-200 rounded-lg p-4 mb-6">
      <h3 class="text-sm font-bold text-gray-900 mb-3">Anexos</h3>
      <div class="grid gap-4 sm:grid-cols-2">
        <% @ticket.attachments.each do |att| %>
          <% if att.image? %>
            <%= link_to url_for(att), target: "_blank", rel: "noopener", class: "group block overflow-hidden rounded-xl border border-violet-200 bg-white" do %>
              <div class="relative h-72 bg-slate-100">
                <%= image_tag att.variant(resize_to_limit: [1200, 1200]),
                  loading: "lazy",
                  class: "h-full w-full object-contain transition-transform duration-300 group-hover:scale-[1.02]" %>

                <div class="pointer-events-none absolute inset-0 flex items-center justify-center bg-slate-900/0 transition-colors duration-300 group-hover:bg-slate-900/35">
                  <span class="inline-flex items-center gap-2 rounded-full bg-white/90 px-3 py-1 text-xs font-semibold text-slate-900 opacity-0 transition-opacity duration-300 group-hover:opacity-100">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35m1.85-5.15a7 7 0 11-14 0 7 7 0 0114 0z" />
                    </svg>
                    Ampliar
                  </span>
                </div>
              </div>

              <p class="px-3 py-2 text-xs font-medium text-violet-700">Clique para abrir em tamanho original</p>
            <% end %>
          <% else %>
            <div class="rounded-xl border border-gray-200 bg-gray-50 p-3 text-sm">
              <%= link_to att.filename.to_s,
                url_for(att),
                target: "_blank",
                rel: "noopener",
                class: "font-semibold text-violet-700 hover:text-violet-900" %>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if can?(:update, @ticket) %>
          <div class="bg-white shadow-sm border border-gray-200 rounded-lg p-4 mb-6">
            <h3 class="text-sm font-bold text-gray-900 mb-3">Atualizar Status</h3>

            <%= form_with(model: @ticket, local: true, class: "flex flex-col sm:flex-row gap-3 items-start sm:items-end") do |f| %>
              <div class="w-full sm:w-72">
                <%= f.label :ticket_status_id, "Status", class: "block mb-2 text-sm font-bold text-gray-800" %>
                <%= f.collection_select :ticket_status_id, TicketStatus.order(:name), :id, :name, {}, class: "bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg block w-full p-3 focus:ring-violet-200 focus:border-violet-500" %>
              </div>

              <% if @ticket.ticket_status&.is_final? && current_user.administrator? %>
                <div class="w-full sm:w-96">
                  <%= f.label :reopen_reason, "Motivo (Obrigatório caso vá reabrir)", class: "block mb-2 text-sm font-bold text-red-800" %>
                  <%= f.text_field :reopen_reason, placeholder: "Ex: Diagnóstico incompleto", class: "bg-red-50 border border-gray-300 text-gray-900 text-sm rounded-lg block w-full p-3 outline-none focus:ring-red-500 focus:border-red-500" %>
                </div>
              <% end %>

              <div>
                <%= f.submit "Salvar", class: "btn-brand px-6 py-2 text-sm" %>
              </div>
            <% end %>
          </div>
        <% end %>

  <div class="mb-8">
    <h3 class="text-xl font-bold text-gray-900 mb-4 border-b pb-2">Histórico da Conversa</h3>
    
    <div class="space-y-4">
      <% if @ticket.comments.empty? %>
        <p class="text-gray-500 italic text-sm bg-gray-50 p-4 rounded-lg text-center border border-dashed border-gray-300">
          Nenhum comentário ainda. Inicie a conversa abaixo.
        </p>
      <% end %>

      <% @ticket.comments.each do |comment| %>
        <div class="bg-white p-4 rounded-lg shadow-sm border border-gray-100">
          <div class="flex justify-between items-center mb-2">
            <span class="font-bold text-violet-900"><%= comment.user.name %></span>
            <span class="text-xs text-gray-400 font-mono"><%= comment.created_at.strftime("%d/%m/%Y às %H:%M") %></span>
          </div>
          <p class="text-gray-700 whitespace-pre-wrap"><%= comment.body %></p>
        </div>
      <% end %>
    </div>
  </div>

  <div class="bg-gray-50 p-6 rounded-lg border border-gray-200 mb-6">
    <% if can?(:create, Comment.new(ticket: @ticket)) %>
      <h4 class="text-lg font-bold text-gray-900 mb-4">Adicionar um Comentário</h4>
      <%= form_with(model: [@ticket, Comment.new], local: true, class: "space-y-4") do |form| %>
        <div>
          <%= form.text_area :body, rows: 3, class: "block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-violet-200 focus:border-violet-500 sm:text-sm", placeholder: "Escreva sua mensagem aqui..." %>
        </div>
        <div>
          <%= form.submit "Enviar Mensagem", class: "btn-brand px-6 py-2 text-sm cursor-pointer" %>
        </div>
      <% end %>
    <% end %>
  </div>

  <div class="flex space-x-4 border-t pt-4">
    <%= link_to "← Voltar para Chamados", tickets_path, class: "text-gray-600 hover:text-gray-900 font-semibold" %>
  </div>
</div>
