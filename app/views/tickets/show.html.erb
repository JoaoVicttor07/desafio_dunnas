<% provide(:title, "Visualizar Chamado | Condomínio Dunnas") %>
<% provide(:page_heading, "Detalhes do Chamado") %>

<div class="max-w-4xl mx-auto mb-10 mt-6">
  
  <div class="flex justify-between items-center mb-6">
    <div>
      <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">
        Chamado #<%= @ticket.id.to_s.rjust(4, '0') %>
      </h1>
      <p class="text-gray-500 mt-1 font-medium"><%= @ticket.ticket_type.title %></p>
    </div>
    <div class="text-right">
      <span class="mb-2 inline-flex rounded-full px-4 py-2 text-sm font-bold leading-5 <%= ticket_status_badge_classes(@ticket.ticket_status) %>">
        <%= @ticket.ticket_status.name %>
      </span>
      <p class="text-sm text-gray-500 font-semibold">
        <%= @ticket.unit.block.identification %> - Apartamento <%= @ticket.unit.identifier %>
      </p>
    </div>
  </div>

  <div class="bg-white shadow overflow-hidden sm:rounded-lg mb-8 border border-gray-200">
    <div class="px-4 py-5 sm:px-6 bg-gray-50 border-b border-gray-200 flex justify-between">
      <h3 class="text-lg leading-6 font-bold text-gray-900">Descrição do Problema</h3>
      <span class="text-sm text-gray-500">Aberto por: <%= @ticket.user.name %></span>
    </div>
    <div class="px-4 py-5 sm:p-6 text-gray-700 whitespace-pre-wrap"><%= @ticket.description %></div>
  </div>

  <% unless current_user.resident? %>
    <div class="bg-white shadow-sm border border-gray-200 rounded-lg p-4 mb-6">
      <div class="mb-4 flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
        <h3 class="text-sm font-bold text-gray-900">SLA do Chamado</h3>
        <span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold <%= ticket_sla_badge_classes(@ticket) %>">
          <%= ticket_sla_status_label(@ticket) %>
        </span>
      </div>

      <div class="grid gap-3 text-sm text-slate-700 sm:grid-cols-2">
        <p><span class="font-semibold text-slate-900">Prazo do tipo:</span> <%= @ticket.ticket_type.sla_hours %>h</p>
        <p><span class="font-semibold text-slate-900">Ciclo SLA:</span> #<%= @ticket.sla_cycle || 1 %></p>
        <p><span class="font-semibold text-slate-900">Inicio do ciclo:</span> <%= @ticket.sla_started_at.present? ? l(@ticket.sla_started_at, format: "%d/%m/%Y %H:%M") : "-" %></p>
        <p><span class="font-semibold text-slate-900">Vencimento:</span> <%= @ticket.sla_due_at.present? ? l(@ticket.sla_due_at, format: "%d/%m/%Y %H:%M") : "-" %></p>
      </div>

      <p class="mt-3 rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-sm font-semibold text-slate-700">
        <%= ticket_sla_timing_label(@ticket) %>
      </p>
    </div>
  <% end %>

  <% if @ticket.attachments.attached? %>
    <div class="bg-white shadow-sm border border-gray-200 rounded-lg p-4 mb-6">
      <h3 class="text-sm font-bold text-gray-900 mb-3">Anexos</h3>
      <div class="grid gap-4 sm:grid-cols-2">
        <% @ticket.attachments.each do |att| %>
          <% if att.image? %>
            <%= link_to url_for(att),
              target: "_blank",
              rel: "noopener",
              data: { lightbox_trigger: true, lightbox_src: url_for(att), lightbox_alt: "Imagem anexa do chamado" },
              class: "group block overflow-hidden rounded-xl border border-violet-200 bg-white" do %>
              <div class="relative h-72 bg-slate-100">
                <%= image_tag att.variant(resize_to_limit: [1200, 1200]),
                  loading: "lazy",
                  class: "h-full w-full object-contain transition-transform duration-300 group-hover:scale-[1.02]" %>

                <div class="pointer-events-none absolute inset-0 flex items-center justify-center bg-slate-900/0 transition-colors duration-300 group-hover:bg-slate-900/35">
                  <span class="inline-flex items-center gap-2 rounded-full bg-white/90 px-3 py-1 text-xs font-semibold text-slate-900 opacity-0 transition-opacity duration-300 group-hover:opacity-100">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35m1.85-5.15a7 7 0 11-14 0 7 7 0 0114 0z" />
                    </svg>
                    Ampliar
                  </span>
                </div>
              </div>

              <p class="px-3 py-2 text-xs font-medium text-violet-700">Clique para ampliar</p>
            <% end %>
          <% else %>
            <div class="rounded-xl border border-gray-200 bg-gray-50 p-3 text-sm">
              <%= link_to att.filename.to_s,
                url_for(att),
                target: "_blank",
                rel: "noopener",
                class: "font-semibold text-violet-700 hover:text-violet-900" %>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>

  <div id="ticket-image-lightbox" class="fixed inset-0 z-[90] hidden items-center justify-center bg-slate-950/70 p-4 backdrop-blur-sm">
    <button type="button" data-lightbox-close class="fixed right-4 top-4 inline-flex h-10 w-10 items-center justify-center rounded-full bg-white/90 text-2xl leading-none text-slate-800 shadow-md hover:bg-white" aria-label="Fechar visualização da imagem">
      &times;
    </button>

    <div data-lightbox-content class="w-full max-w-5xl px-2">
      <img id="ticket-lightbox-image" src="" alt="Imagem ampliada do anexo" class="mx-auto max-h-[78vh] w-auto max-w-full rounded-xl bg-slate-900/40 object-contain shadow-2xl" />
    </div>
  </div>

  <% if can?(:update, @ticket) %>
    <% allowed_next_statuses = @ticket.allowed_next_statuses_for(current_user) %>
    <div class="bg-white shadow-sm border border-gray-200 rounded-lg p-5 mb-6">
      <% current_status = @ticket.ticket_status %>

      <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
        <div class="flex items-start gap-3">
          <span class="mt-0.5 inline-flex h-9 w-9 items-center justify-center rounded-full border <%= ticket_status_indicator_ring_classes(current_status) %>">
            <span class="h-3 w-3 rounded-full <%= ticket_status_indicator_dot_classes(current_status) %>"></span>
          </span>

          <div>
            <div class="flex flex-wrap items-center gap-2">
              <h3 class="text-lg font-bold text-gray-900">Status do chamado</h3>
              <span class="inline-flex rounded-full px-3 py-1 text-xs font-bold leading-5 <%= ticket_status_badge_classes(current_status) %>">
                <%= current_status.name %>
              </span>
            </div>
            <p class="mt-1 text-sm text-slate-500"><%= ticket_status_state_description(current_status) %></p>
          </div>
        </div>

        <% if allowed_next_statuses.any? %>
          <%= form_with(model: @ticket, local: true, class: "w-full lg:w-auto", data: { status_form: true }) do |f| %>
            <%= f.hidden_field :ticket_status_id, value: current_status.id, data: { status_hidden: true, current_status_id: current_status.id } %>

            <div class="flex flex-col gap-3 lg:items-end">
              <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
                <div class="relative w-full sm:min-w-[20rem]" data-status-combobox>
                  <button type="button" class="inline-flex w-full items-center justify-between gap-3 rounded-lg border border-violet-200 bg-white px-4 py-3 text-sm font-semibold text-violet-700 shadow-sm transition-colors hover:bg-violet-50" data-status-toggle aria-expanded="false" aria-haspopup="true">
                    <span class="inline-flex items-center gap-3">
                      <span class="inline-flex h-6 w-6 items-center justify-center rounded-full border <%= ticket_status_indicator_ring_classes(current_status) %>" data-status-trigger-ring>
                        <span class="h-2.5 w-2.5 rounded-full <%= ticket_status_indicator_dot_classes(current_status) %>" data-status-trigger-dot></span>
                      </span>
                      <span class="truncate" data-status-trigger-label><%= current_status.name %></span>
                    </span>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" data-status-chevron>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                    </svg>
                  </button>

                  <div class="absolute right-0 top-[calc(100%+0.5rem)] z-20 hidden w-full overflow-hidden rounded-lg border border-slate-200 bg-white shadow-xl" data-status-menu>
                    <div class="max-h-80 overflow-y-auto p-3">
                      <p class="px-2 pb-2 text-xs font-semibold uppercase tracking-[0.16em] text-slate-400">Selecionar status</p>

                      <div class="space-y-3">
                        <button
                          type="button"
                          class="flex w-full items-center justify-between gap-3 rounded-lg border border-transparent px-3 py-3 text-left transition-colors hover:bg-slate-50"
                          data-status-option
                          data-status-id="<%= current_status.id %>"
                          data-status-name="<%= current_status.name %>"
                          data-status-kind="Atual"
                          data-status-description="<%= ticket_status_state_description(current_status) %>"
                          data-status-final="<%= current_status.is_final?.to_s %>"
                          data-status-reopen="<%= ticket_status_reopened?(current_status).to_s %>"
                          data-status-badge-class="<%= ticket_status_badge_classes(current_status) %>"
                          data-status-ring-class="<%= ticket_status_indicator_ring_classes(current_status) %>"
                          data-status-dot-class="<%= ticket_status_indicator_dot_classes(current_status) %>"
                          data-status-current="true"
                        >
                          <span class="flex items-center gap-3">
                            <span class="inline-flex h-7 w-7 items-center justify-center rounded-full border <%= ticket_status_indicator_ring_classes(current_status) %>">
                              <span class="h-3 w-3 rounded-full <%= ticket_status_indicator_dot_classes(current_status) %>"></span>
                            </span>
                            <span class="flex items-center gap-2">
                              <span class="text-base font-semibold text-slate-900"><%= current_status.name %></span>
                              <span class="rounded bg-slate-200 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wide text-slate-700">Atual</span>
                            </span>
                          </span>
                          <span class="hidden text-violet-600" data-status-check>
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                            </svg>
                          </span>
                        </button>

                        <% ticket_status_transition_groups(allowed_next_statuses).each do |group_label, statuses| %>
                          <div class="space-y-1">
                            <p class="px-3 pt-1 text-[11px] font-semibold uppercase tracking-[0.16em] text-slate-400"><%= group_label %></p>
                            <% statuses.each do |status| %>
                              <button
                                type="button"
                                class="flex w-full items-center justify-between gap-3 rounded-lg border border-transparent px-3 py-3 text-left transition-colors hover:bg-slate-50"
                                data-status-option
                                data-status-id="<%= status.id %>"
                                data-status-name="<%= status.name %>"
                                data-status-kind="<%= ticket_status_transition_kind(status) %>"
                                data-status-description="<%= ticket_status_transition_description(status) %>"
                                data-status-final="<%= status.is_final?.to_s %>"
                                data-status-reopen="<%= ticket_status_reopened?(status).to_s %>"
                                data-status-badge-class="<%= ticket_status_badge_classes(status) %>"
                                data-status-ring-class="<%= ticket_status_indicator_ring_classes(status) %>"
                                data-status-dot-class="<%= ticket_status_indicator_dot_classes(status) %>"
                              >
                                <span class="flex items-center gap-3">
                                  <span class="inline-flex h-7 w-7 items-center justify-center rounded-full border <%= ticket_status_indicator_ring_classes(status) %>">
                                    <span class="h-3 w-3 rounded-full <%= ticket_status_indicator_dot_classes(status) %>"></span>
                                  </span>
                                  <span class="text-base font-semibold text-slate-900"><%= status.name %></span>
                                </span>
                                <span class="hidden text-violet-600" data-status-check>
                                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                                  </svg>
                                </span>
                              </button>
                            <% end %>
                          </div>
                        <% end %>
                      </div>
                    </div>
                  </div>
                </div>

                <button type="button" class="hidden text-sm font-semibold text-slate-600 hover:text-slate-900" data-status-cancel>Cancelar</button>
                <%= f.submit "Salvar", class: "btn-brand hidden px-5 py-3 text-sm", disabled: true, data: { status_submit: true } %>
              </div>
            </div>

            <div class="mt-4 hidden" data-closing-note-field>
              <%= f.label :closing_note, "Parecer (Obrigatório ao concluir)", class: "block mb-2 text-sm font-bold text-gray-800" %>
              <%= f.text_area :closing_note, rows: 2, placeholder: "Ex: Vazamento corrigido, teste de estanqueidade realizado e area liberada.", class: "bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg block w-full p-3 outline-none focus:ring-violet-200 focus:border-violet-500", data: { closing_note_input: true } %>
            </div>

            <% if current_user.administrator? %>
              <div class="mt-4 hidden" data-reopen-reason-field>
                <%= f.label :reopen_reason, "Motivo (Obrigatório caso vá reabrir)", class: "block mb-2 text-sm font-bold text-red-800" %>
                <%= f.text_field :reopen_reason, placeholder: "Ex: Diagnóstico incompleto", class: "bg-red-50 border border-gray-300 text-gray-900 text-sm rounded-lg block w-full p-3 outline-none focus:ring-red-500 focus:border-red-500", data: { reopen_reason_input: true } %>
              </div>
            <% end %>
          <% end %>
        <% else %>
          <div class="rounded-lg border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-600">
            <span class="font-semibold text-slate-700">Status atual:</span> <%= current_status.name %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <div class="mb-8">
    <h3 class="text-xl font-bold text-gray-900 mb-4 border-b pb-2">Histórico da Conversa</h3>
    
    <div class="space-y-4">
      <% if @ticket.comments.empty? %>
        <p class="text-gray-500 italic text-sm bg-gray-50 p-4 rounded-lg text-center border border-dashed border-gray-300">
          Nenhum comentário ainda. Inicie a conversa abaixo.
        </p>
      <% end %>

      <% @ticket.comments.each do |comment| %>
        <div class="bg-white p-4 rounded-lg shadow-sm border border-gray-100">
          <div class="flex justify-between items-center mb-2">
            <span class="font-bold text-violet-900"><%= comment.user.name %></span>
            <span class="text-xs text-gray-400 font-mono"><%= comment.created_at.strftime("%d/%m/%Y às %H:%M") %></span>
          </div>
          <p class="text-gray-700 whitespace-pre-wrap"><%= comment.body %></p>

          <% if comment.photos.attached? %>
            <div class="mt-3 grid gap-4 sm:grid-cols-2">
              <% comment.photos.each do |photo| %>
                <%= link_to url_for(photo),
                  data: { lightbox_trigger: true, lightbox_src: url_for(photo), lightbox_alt: "Imagem anexa do comentario" },
                  class: "group block overflow-hidden rounded-xl border border-violet-200 bg-white" do %>
                  <div class="relative h-56 bg-slate-100">
                    <%= image_tag photo.variant(resize_to_limit: [1200, 1200]),
                      loading: "lazy",
                      class: "h-full w-full object-contain transition-transform duration-300 group-hover:scale-[1.02]" %>

                    <div class="pointer-events-none absolute inset-0 flex items-center justify-center bg-slate-900/0 transition-colors duration-300 group-hover:bg-slate-900/35">
                      <span class="inline-flex items-center gap-2 rounded-full bg-white/90 px-3 py-1 text-xs font-semibold text-slate-900 opacity-0 transition-opacity duration-300 group-hover:opacity-100">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35m1.85-5.15a7 7 0 11-14 0 7 7 0 0114 0z" />
                        </svg>
                        Ampliar
                      </span>
                    </div>
                  </div>

                  <p class="px-3 py-2 text-xs font-medium text-violet-700">Clique para ampliar</p>
                <% end %>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="bg-gray-50 p-6 rounded-lg border border-gray-200 mb-6">
    <% if can?(:create, Comment.new(ticket: @ticket)) %>
      <h4 class="text-lg font-bold text-gray-900 mb-4">Adicionar um Comentário</h4>
      <%= form_with(model: [@ticket, Comment.new], local: true, class: "space-y-4") do |form| %>
        <div>
          <%= form.text_area :body, rows: 3, class: "block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-violet-200 focus:border-violet-500 sm:text-sm", placeholder: "Escreva sua mensagem aqui..." %>
        </div>
        <div class="flex flex-wrap items-center gap-3">
          <%= form.file_field :photos,
            multiple: true,
            accept: "image/png,image/jpeg,image/webp,image/gif,image/heic,image/heif",
            class: "hidden",
            data: { comment_photo_input: true } %>

          <label for="comment_photos" class="inline-flex h-10 w-10 cursor-pointer items-center justify-center rounded-full border border-violet-200 bg-white text-violet-700 transition-colors hover:bg-violet-50" title="Anexar fotos">
            <span class="sr-only">Anexar fotos ao comentario</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 16l5-5 4 4 5-6 4 5M3 19h18M6 7h.01M8 4h8a2 2 0 012 2v10a2 2 0 01-2 2H8a2 2 0 01-2-2V6a2 2 0 012-2z" />
            </svg>
          </label>

          <div class="hidden" data-comment-photo-preview-container>
            <div class="flex flex-wrap gap-2" data-comment-photo-preview-grid></div>
          </div>

          <%= form.submit "Enviar Mensagem", class: "btn-brand px-6 py-2 text-sm cursor-pointer" %>
        </div>
      <% end %>
    <% end %>
  </div>

  <div class="flex space-x-4 border-t pt-4">
    <%= link_to "← Voltar para Chamados", tickets_path, class: "text-gray-600 hover:text-gray-900 font-semibold" %>
  </div>
</div>

<script>
  document.addEventListener("turbo:load", function() {
    const lightbox = document.getElementById("ticket-image-lightbox");
    const lightboxImage = document.getElementById("ticket-lightbox-image");

    if (!lightbox || !lightboxImage) return;
    if (lightbox.dataset.initialized === "true") return;

    lightbox.dataset.initialized = "true";

    const openLightbox = function(src, altText) {
      if (!src) return;

      lightboxImage.src = src;
      lightboxImage.alt = altText || "Imagem ampliada do anexo";
      lightbox.classList.remove("hidden");
      lightbox.classList.add("flex");
      document.body.classList.add("overflow-hidden");
    };

    const closeLightbox = function() {
      lightbox.classList.add("hidden");
      lightbox.classList.remove("flex");
      document.body.classList.remove("overflow-hidden");
      lightboxImage.src = "";
    };

    const triggers = document.querySelectorAll('[data-lightbox-trigger="true"]');
    triggers.forEach(function(trigger) {
      trigger.addEventListener("click", function(event) {
        event.preventDefault();
        openLightbox(this.dataset.lightboxSrc, this.dataset.lightboxAlt);
      });
    });

    const closeButton = lightbox.querySelector('[data-lightbox-close]');
    if (closeButton) {
      closeButton.addEventListener("click", closeLightbox);
    }

    lightbox.addEventListener("click", function(event) {
      if (event.target.closest("[data-lightbox-content]")) return;
      closeLightbox();
    });

    document.addEventListener("keydown", function(event) {
      if (event.key === "Escape" && !lightbox.classList.contains("hidden")) {
        closeLightbox();
      }
    });

    const statusForm = document.querySelector('[data-status-form="true"]');
    if (statusForm) {
      const statusHiddenInput = statusForm.querySelector('[data-status-hidden="true"]');
      const currentStatusId = statusHiddenInput && statusHiddenInput.dataset.currentStatusId;
      const statusToggle = statusForm.querySelector("[data-status-toggle]");
      const statusMenu = statusForm.querySelector("[data-status-menu]");
      const statusChevron = statusForm.querySelector("[data-status-chevron]");
      const statusLabel = statusForm.querySelector("[data-status-trigger-label]");
      const statusRing = statusForm.querySelector("[data-status-trigger-ring]");
      const statusDot = statusForm.querySelector("[data-status-trigger-dot]");
      const statusCancel = statusForm.querySelector("[data-status-cancel]");
      const statusSubmit = statusForm.querySelector('[data-status-submit="true"]');
      const statusOptions = Array.from(statusForm.querySelectorAll("[data-status-option]"));
      const closingNoteField = statusForm.querySelector("[data-closing-note-field]");
      const reopenReasonField = statusForm.querySelector("[data-reopen-reason-field]");
      const closingNoteInput = statusForm.querySelector('[data-closing-note-input="true"]');
      const reopenReasonInput = statusForm.querySelector('[data-reopen-reason-input="true"]');
      const statusChecks = statusForm.querySelectorAll("[data-status-check]");

      const setMenuOpen = function(open) {
        if (!statusMenu) return;

        statusMenu.classList.toggle("hidden", !open);
        if (statusChevron) {
          statusChevron.classList.toggle("rotate-180", open);
        }
        if (statusToggle) {
          statusToggle.setAttribute("aria-expanded", open ? "true" : "false");
        }
      };

      const updateStatusUI = function(option) {
        if (!option || !statusHiddenInput) return;

        statusHiddenInput.value = option.dataset.statusId || currentStatusId;
        if (statusLabel) statusLabel.textContent = option.dataset.statusName || "";
        if (statusRing) statusRing.className = `inline-flex h-6 w-6 items-center justify-center rounded-full border ${option.dataset.statusRingClass || ""}`;
        if (statusDot) statusDot.className = `h-2.5 w-2.5 rounded-full ${option.dataset.statusDotClass || ""}`;

        const changed = option.dataset.statusId !== currentStatusId;
        const concluding = option.dataset.statusFinal === "true";
        const reopening = option.dataset.statusReopen === "true";

        if (closingNoteField) {
          closingNoteField.classList.toggle("hidden", !(changed && concluding));
        }
        if (closingNoteInput) {
          closingNoteInput.required = changed && concluding;
          if (!(changed && concluding)) closingNoteInput.value = "";
        }

        if (reopenReasonField) {
          reopenReasonField.classList.toggle("hidden", !(changed && reopening));
        }
        if (reopenReasonInput) {
          reopenReasonInput.required = changed && reopening;
          if (!(changed && reopening)) reopenReasonInput.value = "";
        }

        if (statusCancel) {
          statusCancel.classList.toggle("hidden", !changed);
        }

        if (statusSubmit) {
          statusSubmit.disabled = !changed;
          statusSubmit.classList.toggle("hidden", !changed);
        }

        statusOptions.forEach((statusOption) => {
          statusOption.classList.remove("bg-violet-50", "border-violet-200");
          statusOption.classList.add("border-transparent");
        });

        option.classList.add("bg-violet-50", "border-violet-200");
        option.classList.remove("border-transparent");

        statusChecks.forEach((check) => check.classList.add("hidden"));
        const activeCheck = option.querySelector("[data-status-check]");
        if (activeCheck) {
          activeCheck.classList.remove("hidden");
        }
      };

      if (statusToggle) {
        statusToggle.addEventListener("click", function() {
          setMenuOpen(statusMenu.classList.contains("hidden"));
        });
      }

      statusOptions.forEach((option) => {
        option.addEventListener("click", function() {
          updateStatusUI(option);
          setMenuOpen(false);
        });
      });

      if (statusCancel) {
        statusCancel.addEventListener("click", function() {
          const currentOption = statusOptions.find((option) => option.dataset.statusId === currentStatusId);
          if (currentOption) {
            updateStatusUI(currentOption);
          }
          setMenuOpen(false);
        });
      }

      document.addEventListener("click", function(event) {
        if (!statusForm.contains(event.target)) {
          setMenuOpen(false);
        }
      });

      const initialOption = statusOptions.find((option) => option.dataset.statusId === currentStatusId) || statusOptions[0];
      if (initialOption) {
        updateStatusUI(initialOption);
      }
    }

    const commentPhotoInput = document.querySelector('[data-comment-photo-input="true"]');
    const commentPhotoPreviewContainer = document.querySelector("[data-comment-photo-preview-container]");
    const commentPhotoPreviewGrid = document.querySelector("[data-comment-photo-preview-grid]");

    if (commentPhotoInput && commentPhotoPreviewContainer && commentPhotoPreviewGrid) {
      const renderCommentPhotoPreviews = function(files) {
        commentPhotoPreviewGrid.innerHTML = "";

        if (!files || files.length === 0) {
          commentPhotoPreviewContainer.classList.add("hidden");
          return;
        }

        commentPhotoPreviewContainer.classList.remove("hidden");

        Array.from(files).forEach(function(file, index) {
          if (!file.type.startsWith("image/")) return;

          const previewButton = document.createElement("button");
          previewButton.type = "button";
          previewButton.className = "group relative h-12 w-12 overflow-hidden rounded-lg border border-violet-200 bg-white";
          previewButton.title = "Remover foto";

          const image = document.createElement("img");
          image.className = "h-full w-full object-cover";
          image.alt = "Pre-visualizacao da foto anexada";

          const overlay = document.createElement("span");
          overlay.className = "pointer-events-none absolute inset-0 flex items-center justify-center bg-slate-900/55 text-white opacity-0 transition-opacity group-hover:opacity-100";
          overlay.innerHTML = "<svg xmlns=\"http://www.w3.org/2000/svg\" class=\"h-4 w-4\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M6 18L18 6M6 6l12 12\" /></svg>";

          const reader = new FileReader();
          reader.onload = function(event) {
            image.src = event.target.result;
          };
          reader.readAsDataURL(file);

          previewButton.addEventListener("click", function() {
            const dataTransfer = new DataTransfer();

            Array.from(commentPhotoInput.files).forEach(function(currentFile, currentIndex) {
              if (currentIndex !== index) {
                dataTransfer.items.add(currentFile);
              }
            });

            commentPhotoInput.files = dataTransfer.files;
            renderCommentPhotoPreviews(commentPhotoInput.files);
          });

          previewButton.appendChild(image);
          previewButton.appendChild(overlay);
          commentPhotoPreviewGrid.appendChild(previewButton);
        });
      };

      commentPhotoInput.addEventListener("change", function() {
        renderCommentPhotoPreviews(commentPhotoInput.files);
      });

      if (commentPhotoInput.files && commentPhotoInput.files.length > 0) {
        renderCommentPhotoPreviews(commentPhotoInput.files);
      }
    }
  });
</script>
