<% content_for :title, "Tickets" %>

<div class="w-full">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">Meus Chamados</h1>
    <%= link_to "Novo Chamado", new_ticket_path, class: "bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded-lg shadow-sm transition-colors" %>
  </div>

  <div class="bg-white shadow-md rounded-xl overflow-hidden border border-gray-200">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">ID</th>
          <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Apartamento</th>
          <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Problema</th>
          <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Status</th>
          <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider text-right">Ações</th>
        </tr>
      </thead>
      
      <tbody class="bg-white divide-y divide-gray-200">
        <% @tickets.each do |ticket| %>
          <tr class="hover:bg-gray-50 transition-colors">
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 font-mono">
              # <%= ticket.id.to_s.rjust(4, '0') %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm font-bold text-gray-900">
              <%= ticket.unit.block.identification %> - Apto <%= ticket.unit.identifier %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
              <%= ticket.ticket_type.title %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <span class="px-3 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-blue-100 text-blue-800">
                <%= ticket.ticket_status.name %>
              </span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-right">
              <%= link_to "Ver Detalhes", ticket, class: "text-blue-600 hover:text-blue-900 font-semibold" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    
    <% if @tickets.empty? %>
      <div class="text-center py-10">
        <p class="text-gray-500">Nenhum chamado encontrado.</p>
      </div>
    <% end %>
  </div>
</div>
