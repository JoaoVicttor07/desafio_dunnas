<% provide(:title, "Meus Chamados | Condomínio Dunnas") %>

<div class="w-full">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">Meus Chamados</h1>
    <%= link_to "Novo Chamado", new_ticket_path, class: "bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded-lg shadow-sm transition-colors" %>
  </div>

  <div class="bg-white shadow-md rounded-xl overflow-hidden overflow-x-auto border border-gray-200">

    <%= form_with url: tickets_path, method: :get, local: true, class: "mb-6 flex flex-col md:flex-row gap-3" do %>
      <div>
        <%= label_tag :ticket_status_id, "Status", class: "block text-sm font-bold text-gray-800 mb-1" %>
        <%= select_tag :ticket_status_id,
        options_from_collection_for_select(TicketStatus.order(:name), :id, :name, params[:ticket_status_id]),
        include_blank: "Todos",
        class: "bg-gray-50 border border-gray-300 rounded-lg p-2" %>
      </div>

      <div>
        <%= label_tag :ticket_type_id, "Tipo", class: "block text-sm font-bold text-gray-800 mb-1" %>
        <%= select_tag :ticket_type_id,
        options_from_collection_for_select(TicketType.order(:title), :id, :title, params[:ticket_type_id]),
        include_blank: "Todos",
        class: "bg-gray-50 border border-gray-300 rounded-lg p-2" %>
      </div>

      <% if current_user.resident? %>
        <div>
          <%= label_tag :unit_id, "Unidade", class: "block text-sm font-bold text-gray-800 mb-1" %>
          <%= select_tag :unit_id,
          options_from_collection_for_select(current_user.units.includes(:block), :id, :identifier, params[:unit_id]),
          include_blank: "Todas",
          class: "bg-gray-50 border border-gray-300 rounded-lg p-2" %>
        </div>
      <% end %>

      <div class="flex items-end gap-2">
        <%= submit_tag "Filtrar", class: "bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded-lg" %>
        <%= link_to "Limpar", tickets_path, class: "bg-gray-100 hover:bg-gray-200 text-gray-800 font-bold py-2 px-4 rounded-lg" %>
      </div>
    <% end %>

    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">ID</th>
          <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Apartamento</th>
          <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Problema</th>
          <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Status</th>
          <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider text-right">Ações</th>
        </tr>
      </thead>
      
      <tbody class="bg-white divide-y divide-gray-200">
        <% @tickets.each do |ticket| %>
          <tr class="hover:bg-gray-50 transition-colors">
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 font-mono">
              # <%= ticket.id.to_s.rjust(4, '0') %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm font-bold text-gray-900">
              <%= ticket.unit.block.identification %> - Apto <%= ticket.unit.identifier %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
              <%= ticket.ticket_type.title %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <span class="px-3 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-blue-100 text-blue-800">
                <%= ticket.ticket_status.name %>
              </span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-right">
              <%= link_to "Ver Detalhes", ticket, class: "text-blue-600 hover:text-blue-900 font-semibold" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    
    <% if @tickets.empty? %>
      <div class="text-center py-10">
        <p class="text-gray-500">Nenhum chamado encontrado.</p>
      </div>
    <% end %>
  </div>
</div>
