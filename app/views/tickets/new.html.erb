<% provide(:title, "Novo Chamado | Condomínio Dunnas") %>

<div class="max-w-3xl mx-auto mt-10">
  <div class="bg-white p-8 md:p-10 rounded-2xl shadow-lg border border-gray-100">
    <div class="mb-8">
      <h1 class="text-3xl font-extrabold text-gray-900">Abrir Novo Chamado</h1>
      <p class="text-gray-500 mt-2 text-sm">Preencha as informações abaixo com o máximo de detalhes possível para agilizarmos o seu atendimento.</p>
    </div>

    <%= render "form", ticket: @ticket %>
  </div>

  <div class="mt-8 text-center mb-10">
    <%= link_to "← Voltar para Meus Chamados", tickets_path, class: "text-gray-500 hover:text-blue-600 font-semibold transition-colors" %>
  </div>
</div>
