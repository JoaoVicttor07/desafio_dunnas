<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for?(:title) ? yield(:title) : "Condomínio Dunnas" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-50 min-h-screen text-gray-900 font-sans">
    
    <nav class="bg-blue-900 text-white shadow-md">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col sm:flex-row justify-between items-center py-4 sm:py-0 sm:h-16 gap-4 sm:gap-0">
          
          <div class="flex-shrink-0 font-extrabold text-2xl tracking-tight text-center sm:text-left">
            <%= link_to "Condomínio Dunnas", 
              (user_signed_in? && current_user.collaborator? ? tickets_path : root_path), 
              class: "hover:text-blue-200 transition-colors" %>
          </div>

          <div class="flex flex-wrap justify-center items-center gap-3">
            <% if user_signed_in? %>
              <% unless current_user.collaborator? %>
                <%= link_to "Blocos e Unidades", blocks_path, class: "px-3 py-2 rounded-md text-sm font-medium hover:bg-blue-800 transition-colors" %>
              <% end %>

              <%= link_to "Meus Chamados", tickets_path, class: "px-3 py-2 rounded-md text-sm font-medium hover:bg-blue-800 transition-colors" %>
              <% if current_user.administrator? %>
                <%= link_to "Usuários", admin_users_path, class: "px-3 py-2 rounded-md text-sm font-medium hover:bg-blue-800 transition-colors" %>
                <%= link_to "Vínculos", admin_user_units_path, class: "px-3 py-2 rounded-md text-sm font-medium hover:bg-blue-800 transition-colors" %>
              <% end %>
              
              <div class="hidden sm:block border-l border-blue-700 h-6 mx-1"></div>
              
              <span class="text-blue-200 text-sm font-medium">
                Olá, <%= current_user.name.split.first %>
              </span>
              
              <%= button_to "Sair", destroy_user_session_path, method: :delete, class: "bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded-md text-sm font-bold shadow transition-colors cursor-pointer" %>
            <% else %>
              <% unless devise_controller? %>
                <%= link_to "Entrar", new_user_session_path, class: "text-blue-100 hover:text-white font-medium px-3 py-2 text-sm transition-colors" %>
                <%= link_to "Criar Conta", new_user_registration_path, class: "bg-blue-600 hover:bg-blue-500 text-white px-5 py-2 rounded-md text-sm font-bold shadow transition-colors" %>
              <% end %>
            <% end %>
          </div>
        </div>
      </div>
    </nav>

    <div class="max-w-6xl mx-auto px-4 mt-6">
      <% if notice %>
        <div class="bg-green-50 border-l-4 border-green-500 p-4 mb-4 rounded shadow-sm">
          <p class="text-sm text-green-700 font-semibold"><%= notice %></p>
        </div>
      <% end %>
      
      <% if alert %>
        <div class="bg-red-50 border-l-4 border-red-500 p-4 mb-4 rounded shadow-sm">
          <p class="text-sm text-red-700 font-semibold"><%= alert %></p>
        </div>
      <% end %>
    </div>

    <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pb-12">
      <%= yield %>
    </main>
    
  </body>
</html>
