<ul class="space-y-1">
  <% items.each do |item| %>
    <% active = navigation_item_active?(item) %>
    <li>
      <%= link_to item[:path], class: navigation_link_classes(active, mobile: mobile) do %>
        <span class="inline-flex h-7 w-7 items-center justify-center rounded-lg text-xs font-bold <%= active ? 'bg-blue-100 text-blue-900' : 'bg-white/20 text-white' %>">
          <%= item[:label].first %>
        </span>
        <span><%= item[:label] %></span>
      <% end %>
    </li>
  <% end %>
</ul>