<% content_for :title, "Tipos de chamado" %>
<% provide(:page_heading, "Tipos de Chamado") %>

<div class="w-full">
  <div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <h1 class="font-display text-4xl font-extrabold tracking-tight text-slate-900">Tipos de chamado</h1>
      <p class="mt-1 text-sm text-slate-500">Defina categorias e SLA para padronizar os atendimentos.</p>
    </div>

    <% if can?(:create, TicketType) %>
      <%= link_to "Novo Tipo", new_ticket_type_path, class: "btn-brand inline-flex items-center justify-center px-5 py-2.5 text-sm" %>
    <% end %>
  </div>

  <div id="ticket_types" class="panel-surface min-w-full divide-y divide-violet-100/80 rounded-2xl p-4 space-y-4">
    <% if @ticket_types.any? %>
      <% @ticket_types.each do |ticket_type| %>
        <div class="flex flex-col gap-4 rounded-xl border border-violet-100 bg-white p-4 sm:flex-row sm:items-center sm:justify-between">
          <%= render ticket_type %>
          <div class="flex w-full flex-col gap-2 sm:w-auto sm:flex-row">

            <% if can?(:update, ticket_type) %>
              <%= link_to "Editar", edit_ticket_type_path(ticket_type), class: "btn-brand-soft w-full px-3.5 py-2.5 text-center text-sm sm:w-auto" %>
            <% end %>

            <% if can?(:destroy, ticket_type) %>
              <%= button_to "Excluir", ticket_type, method: :delete, class: "w-full rounded-xl bg-rose-600 px-3.5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-rose-700 cursor-pointer sm:w-auto", data: { turbo_confirm: "Você tem certeza?" } %>
            <% end %>

          </div>
        </div>
      <% end %>
    <% else %>
      <p class="my-10 text-center text-sm font-medium text-slate-500">Nenhum tipo de chamado encontrado.</p>
    <% end %>
  </div>
</div>
