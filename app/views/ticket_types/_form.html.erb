<%= form_with(model: ticket_type, class: "contents") do |form| %>
  <% if ticket_type.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2>
        <%= pluralize(ticket_type.errors.count, "erro impediu", "erros impediram") %> o tipo de chamado de ser salvo:
      </h2>

      <ul class="list-disc ml-6">
        <% ticket_type.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5">
    <%= form.label :title, "Título" %>
    <%= form.text_field :title, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": ticket_type.errors[:title].none?, "border-red-400 focus:outline-red-600": ticket_type.errors[:title].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :sla_hours, "Prazo (SLA em horas)" %>
    <%= form.number_field :sla_hours, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": ticket_type.errors[:sla_hours].none?, "border-red-400 focus:outline-red-600": ticket_type.errors[:sla_hours].any?}] %>
  </div>

  <div class="my-5 p-4 border rounded-md bg-gray-50 border-gray-200">
    <h3 class="font-medium text-gray-700 mb-3">Colaboradores responsáveis</h3>

    <%= form.collection_select :collaborator_ids, User.collaborator, :id, :name, {}, { multiple: true, data: { controller: "tom-select" }, class: "w-full" } %>

    <p class="text-xs text-gray-500 mt-2">Você pode pesquisar e selecionar múltiplos colaboradores simultaneamente.</p>
  </div>

  <div class="inline">
    <%= form.submit "Salvar", class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
  </div>
<% end %>
