<% provide(:title, "Notificações | Condomínio Dunnas") %>
<% provide(:page_heading, "Notificações") %>

<div class="w-full">
  <div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <h1 class="font-display text-4xl font-extrabold tracking-tight text-slate-900">Notificações</h1>
      <p class="mt-1 text-sm text-slate-500">Acompanhe mudanças de status e novos comentários nos chamados do seu escopo.</p>
    </div>

    <% unread_count = current_user.notifications.unread.count %>
    <% if unread_count.positive? %>
      <%= button_to "Marcar todas como lidas", mark_all_as_read_notifications_path, method: :patch, class: "btn-brand-soft px-4 py-2 text-sm" %>
    <% end %>
  </div>

  <div class="panel-surface overflow-hidden rounded-2xl">
    <% if @notifications.any? %>
      <ul class="divide-y divide-violet-100/80">
        <% @notifications.each do |notification| %>
          <li class="px-5 py-4 transition-colors <%= notification.read_at? ? 'bg-white/70' : 'bg-violet-50/50' %>">
            <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
              <div>
                <p class="text-sm font-bold text-slate-900"><%= notification.title %></p>
                <p class="mt-1 text-sm text-slate-600"><%= notification.body %></p>

                <div class="mt-2 flex flex-wrap items-center gap-3 text-xs text-slate-500">
                  <span><%= l(notification.created_at, format: "%d/%m/%Y %H:%M") %></span>
                  <% if notification.actor.present? %>
                    <span>por <%= notification.actor.name %></span>
                  <% end %>
                  <% if notification.ticket.present? %>
                    <%= link_to "Ver chamado ##{notification.ticket.id.to_s.rjust(4, '0')}", ticket_path(notification.ticket), class: "font-semibold text-violet-700 hover:text-violet-900" %>
                  <% end %>
                </div>
              </div>

              <% unless notification.read_at? %>
                <%= button_to "Marcar como lida", notification_path(notification), method: :patch, class: "btn-brand-soft px-3 py-2 text-xs" %>
              <% else %>
                <span class="inline-flex rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600">Lida</span>
              <% end %>
            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <div class="py-14 text-center">
        <p class="text-sm font-medium text-slate-500">Nenhuma notificação ainda.</p>
      </div>
    <% end %>
  </div>
</div>