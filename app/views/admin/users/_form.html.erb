<%= form_with(model: [:admin, user], class: "space-y-6") do |f| %>
  <% if user.errors.any? %>
    <div class="bg-red-50 border-l-4 border-red-500 p-4 rounded">
      <ul class="text-sm text-red-700 list-disc list-inside">
        <% user.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, "Nome", class: "block text-sm font-bold text-gray-700 mb-1" %>
    <%= f.text_field :name, class: "w-full px-4 py-3 border border-gray-300 rounded-lg" %>
  </div>

  <div>
    <%= f.label :email, "E-mail", class: "block text-sm font-bold text-gray-700 mb-1" %>
    <%= f.email_field :email, class: "w-full px-4 py-3 border border-gray-300 rounded-lg" %>
  </div>

  <div>
    <%= f.label :role, "Role", class: "block text-sm font-bold text-gray-700 mb-1" %>

    <% if user.persisted? && user.administrator? %>
      <div class="w-full px-4 py-3 border border-gray-300 rounded-lg bg-gray-50 text-gray-700">
        Administrador
      </div>
    <% else %>
      <%= f.select :role, User.roles.keys.map { |r| [r.humanize, r] }, {}, class: "w-full px-4 py-3 border border-gray-300 rounded-lg" %>
    <% end %>
  </div>

  <div>
    <%= f.label :password, "Senha (opcional)", class: "block text-sm font-bold text-gray-700 mb-1" %>
    <%= f.password_field :password, class: "w-full px-4 py-3 border border-gray-300 rounded-lg" %>
  </div>

  <div>
    <%= f.label :password_confirmation, "Confirmação (opcional)", class: "block text-sm font-bold text-gray-700 mb-1" %>
    <%= f.password_field :password_confirmation, class: "w-full px-4 py-3 border border-gray-300 rounded-lg" %>
  </div>

  <div class="flex justify-end">
    <%= f.submit "Salvar", class: "bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded-lg" %>
  </div>
<% end %>