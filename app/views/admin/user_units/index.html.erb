<% provide(:title, "Vínculos | Condomínio Dunnas") %>

<div class="w-full">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">Vínculos (Morador ↔ Unidade)</h1>
  </div>

  <div class="bg-white p-6 rounded-xl shadow-md border border-gray-200 mb-8">
    <h2 class="text-lg font-bold text-gray-900 mb-4">Novo Vínculo</h2>

    <%= form_with(model: [:admin, @user_unit], url: admin_user_units_path, class: "grid grid-cols-1 md:grid-cols-3 gap-4") do |f| %>
      <div>
        <%= f.label :user_id, "Morador", class: "block text-sm font-bold text-gray-700 mb-1" %>
        <%= f.select :user_id,
          options_from_collection_for_select(@residents, :id, :name),
          { prompt: "Selecione..." },
          class: "w-full px-4 py-3 border border-gray-300 rounded-lg" %>
      </div>

      <div>

        <div>
            <%= label_tag :block_id, "Bloco/Torre", class: "block text-sm font-bold text-gray-700 mb-1" %>
            <%= select_tag :block_id,
            options_from_collection_for_select(@blocks, :id, :identification),
            prompt: "Selecione...",
            id: "admin-block-select",
            class: "w-full px-4 py-3 border border-gray-300 rounded-lg" %>
        </div>

        <div>
            <%= f.label :unit_id, "Unidade", class: "block text-sm font-bold text-gray-700 mb-1" %>
            <%= f.select :unit_id,
            [],
            { prompt: "Selecione o bloco primeiro..." },
             {
                id: "admin-unit-select",
                disabled: true,
                class: "w-full px-4 py-3 border border-gray-300 rounded-lg"
            } %>
        </div>

      </div>

      <div class="flex items-end">
        <%= f.submit "Vincular", class: "w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-4 rounded-lg" %>
      </div>
    <% end %>
  </div>

  <div class="bg-white shadow-md rounded-xl overflow-hidden overflow-x-auto border border-gray-200">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Morador</th>
          <th class="px-6 py-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Unidade</th>
          <th class="px-6 py-4 text-right text-xs font-bold text-gray-500 uppercase tracking-wider">Ações</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @user_units.each do |uu| %>
          <tr class="hover:bg-gray-50 transition-colors">
            <td class="px-6 py-4 whitespace-nowrap text-sm font-bold text-gray-900"><%= uu.user.name %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
              <%= uu.unit.block.identification %> - <%= uu.unit.identifier %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-right">
              <%= link_to "Excluir", admin_user_unit_path(uu),
                data: { turbo_method: :delete, turbo_confirm: "Tem certeza?" },
                class: "text-red-600 hover:text-red-900 font-semibold" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <% if @user_units.empty? %>
      <div class="text-center py-10">
        <p class="text-gray-500">Nenhum vínculo criado ainda.</p>
      </div>
    <% end %>
  </div>
</div>

<script>
  document.addEventListener("turbo:load", function() {
    const blockSelect = document.getElementById("admin-block-select");
    const unitSelect = document.getElementById("admin-unit-select");

    if (!blockSelect || !unitSelect) return;

    async function loadUnits(blockId) {
      unitSelect.innerHTML = '<option value="">Carregando...</option>';
      unitSelect.disabled = true;

      try {
        const response = await fetch(`/admin/units?block_id=${encodeURIComponent(blockId)}`, {
          headers: { "Accept": "application/json" }
        });

        if (!response.ok) {
          throw new Error(`HTTP ${response.status}`);
        }

        const units = await response.json();

        unitSelect.innerHTML = '<option value="">Selecione...</option>';

        units.forEach((u) => {
          const option = document.createElement("option");
          option.value = u.id;
          option.text = u.label;
          unitSelect.appendChild(option);
        });

        unitSelect.disabled = false;
        
      } catch (error) {
        console.error("Failed to load units:", error);
        unitSelect.innerHTML = '<option value="">Erro ao carregar unidades</option>';
        unitSelect.disabled = true;
      }
    }

    blockSelect.addEventListener("change", function() {
      const blockId = this.value;

      if (!blockId) {
        unitSelect.innerHTML = '<option value="">Selecione o bloco primeiro...</option>';
        unitSelect.disabled = true;
        return;
      }

      loadUnits(blockId);
    });
  });
</script>