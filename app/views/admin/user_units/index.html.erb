<% provide(:title, "Vínculos | Condomínio Dunnas") %>
<% provide(:page_heading, "Vinculos") %>

<div class="w-full">
  <div class="flex justify-between items-center mb-6">
    <h1 class="font-display text-4xl font-extrabold tracking-tight text-slate-900">Vinculos (Morador <-> Unidade)</h1>
  </div>

  <div class="panel-surface mb-8 rounded-2xl p-6">
    <h2 class="text-lg font-bold text-gray-900 mb-4">Novo Vínculo</h2>

    <%= form_with(model: [:admin, @user_unit], url: admin_user_units_path, class: "grid grid-cols-1 md:grid-cols-3 gap-4") do |f| %>
      <div>
        <%= f.label :user_id, "Morador", class: "block text-sm font-bold text-gray-700 mb-1" %>
        <%= f.select :user_id,
          options_from_collection_for_select(@residents, :id, :name),
          { prompt: "Selecione..." },
          class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:border-violet-500 focus:outline-none focus:ring-2 focus:ring-violet-100" %>
      </div>

      <div>

        <div>
            <%= label_tag :block_id, "Bloco/Torre", class: "block text-sm font-bold text-gray-700 mb-1" %>
            <%= select_tag :block_id,
            options_from_collection_for_select(@blocks, :id, :identification),
            prompt: "Selecione...",
            id: "admin-block-select",
            class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:border-violet-500 focus:outline-none focus:ring-2 focus:ring-violet-100" %>
        </div>

        <div>
            <%= f.label :unit_id, "Unidade", class: "block text-sm font-bold text-gray-700 mb-1" %>
            <%= f.select :unit_id,
            [],
            { prompt: "Selecione o bloco primeiro..." },
             {
                id: "admin-unit-select",
                disabled: true,
              class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:border-violet-500 focus:outline-none focus:ring-2 focus:ring-violet-100"
            } %>
        </div>

      </div>

      <div class="flex items-end">
        <%= f.submit "Vincular", class: "btn-brand w-full py-3 px-4 text-sm" %>
      </div>
    <% end %>
  </div>

  <div class="panel-surface overflow-hidden rounded-2xl">
    <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-violet-100/80">
      <thead class="bg-violet-50/60">
        <tr>
          <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-wider text-violet-700">Morador</th>
          <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-wider text-violet-700">Unidade</th>
          <th class="px-6 py-4 text-right text-xs font-bold uppercase tracking-wider text-violet-700">Acoes</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-violet-100/80 bg-white/95">
        <% @user_units.each do |uu| %>
          <tr class="transition-colors hover:bg-violet-50/60">
            <td class="whitespace-nowrap px-6 py-4 text-sm font-bold text-slate-900"><%= uu.user.name %></td>
            <td class="whitespace-nowrap px-6 py-4 text-sm text-slate-600">
              <%= uu.unit.block.identification %> - <%= uu.unit.identifier %>
            </td>
            <td class="whitespace-nowrap px-6 py-4 text-sm font-medium text-right">
              <%= link_to "Excluir", admin_user_unit_path(uu),
                data: { turbo_method: :delete, turbo_confirm: "Tem certeza?" },
                class: "font-semibold text-rose-600 hover:text-rose-800" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    </div>

    <% if @user_units.empty? %>
      <div class="py-12 text-center">
        <p class="text-sm font-medium text-slate-500">Nenhum vinculo criado ainda.</p>
      </div>
    <% end %>
  </div>
</div>

<script>
  document.addEventListener("turbo:load", function() {
    const blockSelect = document.getElementById("admin-block-select");
    const unitSelect = document.getElementById("admin-unit-select");

    if (!blockSelect || !unitSelect) return;

    async function loadUnits(blockId) {
      unitSelect.innerHTML = '<option value="">Carregando...</option>';
      unitSelect.disabled = true;

      try {
        const response = await fetch(`/admin/units?block_id=${encodeURIComponent(blockId)}`, {
          headers: { "Accept": "application/json" }
        });

        if (!response.ok) {
          throw new Error(`HTTP ${response.status}`);
        }

        const units = await response.json();

        unitSelect.innerHTML = '<option value="">Selecione...</option>';

        units.forEach((u) => {
          const option = document.createElement("option");
          option.value = u.id;
          option.text = u.label;
          unitSelect.appendChild(option);
        });

        unitSelect.disabled = false;
        
      } catch (error) {
        console.error("Failed to load units:", error);
        unitSelect.innerHTML = '<option value="">Erro ao carregar unidades</option>';
        unitSelect.disabled = true;
      }
    }

    blockSelect.addEventListener("change", function() {
      const blockId = this.value;

      if (!blockId) {
        unitSelect.innerHTML = '<option value="">Selecione o bloco primeiro...</option>';
        unitSelect.disabled = true;
        return;
      }

      loadUnits(blockId);
    });
  });
</script>