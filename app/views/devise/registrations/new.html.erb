<% provide(:title, "Nova Conta | Condomínio Dunnas") %>

<div class="min-h-[80vh] flex flex-col justify-center max-w-md w-full mx-auto px-4 sm:px-0">
  <div class="bg-white p-8 border border-gray-200 rounded-2xl shadow-xl">
    
    <div class="text-center mb-8">
      <h2 class="text-3xl font-extrabold text-gray-900">Nova Conta</h2>
      <p class="text-gray-500 mt-2 text-sm">Junte-se ao Condomínio Dunnas.</p>
    </div>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-6" }) do |f| %>
      
      <%= render "devise/shared/error_messages", resource: resource %>

      <div>
        <%= f.label :name, "Nome Completo", class: "block text-sm font-bold text-gray-700 mb-1" %>
        <%= f.text_field :name, autofocus: true, autocomplete: "name", class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" %>
      </div>

      <div>
        <%= f.label :email, "E-mail", class: "block text-sm font-bold text-gray-700 mb-1" %>
        <%= f.email_field :email, autocomplete: "email", class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" %>
      </div>

      <div>
        <%= f.label :password, "Senha", class: "block text-sm font-bold text-gray-700 mb-1" %>
        <% if @minimum_password_length %>
          <span class="text-xs text-gray-500">(Mínimo de <%= @minimum_password_length %> caracteres)</span>
        <% end %>
        <%= f.password_field :password, autocomplete: "new-password", class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" %>
      </div>

      <div>
        <%= f.label :password_confirmation, "Confirme sua Senha", class: "block text-sm font-bold text-gray-700 mb-1" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" %>
      </div>

      <div>
        <%= f.submit "Cadastrar", class: "w-full flex justify-center py-3 px-4 border border-transparent rounded-lg shadow-sm text-base font-extrabold text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-4 focus:ring-blue-300 transition-all cursor-pointer" %>
      </div>
    <% end %>
  </div>

  <div class="mt-6 text-center text-sm font-medium text-gray-600">
    <%= render "devise/shared/links" %>
  </div>
</div>
