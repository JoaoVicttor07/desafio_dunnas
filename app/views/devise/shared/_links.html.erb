<div class="flex flex-col space-y-3 mt-4">
  <%- if controller_name != 'sessions' %>
    <%= link_to "Já possui uma conta? Entrar", new_session_path(resource_name), class: "text-blue-600 hover:text-blue-800 transition-colors" %>
  <% end %>

  <%- if devise_mapping.registerable? && controller_name != 'registrations' %>
    <%= link_to "Não tem conta? Criar agora", new_registration_path(resource_name), class: "text-blue-600 hover:text-blue-800 transition-colors" %>
  <% end %>

  <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
    <%= link_to "Esqueceu sua senha?", new_password_path(resource_name), class: "text-gray-500 hover:text-gray-800 transition-colors" %>
  <% end %>
</div>