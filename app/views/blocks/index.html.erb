<div class="w-full">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">Gestão de Blocos</h1>
    <%= link_to "Novo Bloco", new_block_path, class: "bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded-lg shadow-sm transition-colors" %>
  </div>

  <div class="bg-white shadow-md rounded-xl overflow-hidden border border-gray-200">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">ID</th>
          <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Identificação</th>
          <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Andares</th>
          <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Apts / Andar</th>
          <th scope="col" class="px-6 py-4 text-right text-xs font-bold text-gray-500 uppercase tracking-wider">Ações</th>
        </tr>
      </thead>
      
      <tbody class="bg-white divide-y divide-gray-200">
        <% @blocks.each do |block| %>
          <tr class="hover:bg-gray-50 transition-colors">
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 font-mono">
              # <%= block.id.to_s.rjust(3, '0') %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm font-bold text-gray-900">
              <%= block.identification %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
              <%= block.floors_count %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
              <%= block.apartments_per_floor %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-right space-x-3">
              <%= link_to "Ver", block, class: "text-blue-600 hover:text-blue-900 font-semibold" %>
              <%= link_to "Editar", edit_block_path(block), class: "text-amber-600 hover:text-amber-900 font-semibold" %>
              
              <%= link_to "Excluir", block, data: { turbo_method: :delete, turbo_confirm: "Tem certeza que deseja excluir esta torre?" }, class: "text-red-600 hover:text-red-900 font-semibold" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    
    <% if @blocks.empty? %>
      <div class="text-center py-10">
        <p class="text-gray-500">Nenhum bloco ou torre cadastrada ainda.</p>
      </div>
    <% end %>
  </div>
</div>