<%= form_with(model: block, class: "contents") do |form| %>
  <% if block.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(block.errors.count, "error") %> prohibited this block from being saved:</h2>

      <ul class="list-disc ml-6">
        <% block.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5">
    <%= form.label :identification %>
    <%= form.text_field :identification, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": block.errors[:identification].none?, "border-red-400 focus:outline-red-600": block.errors[:identification].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :floors_count %>
    <%= form.number_field :floors_count, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": block.errors[:floors_count].none?, "border-red-400 focus:outline-red-600": block.errors[:floors_count].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :apartments_per_floor %>
    <%= form.number_field :apartments_per_floor, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": block.errors[:apartments_per_floor].none?, "border-red-400 focus:outline-red-600": block.errors[:apartments_per_floor].any?}] %>
  </div>

  <div class="inline">
    <%= form.submit class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
  </div>
<% end %>
