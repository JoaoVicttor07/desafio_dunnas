<% provide(:title, "Visualizar Bloco | Condomínio Dunnas") %>

<% provide(:title, "Detalhes: #{@block.identification} | Condomínio Dunnas") %>

<div class="max-w-3xl mx-auto mt-10">
  <div class="bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden">
    
    <div class="bg-blue-50 border-b border-blue-100 p-6 flex justify-between items-center">
      <div>
        <h1 class="text-2xl font-extrabold text-blue-900">
          <%= @block.identification %>
        </h1>
        <p class="text-blue-600 text-sm mt-1">Detalhes estruturais da torre</p>
      </div>
      <span class="bg-blue-600 text-white text-xs font-bold px-3 py-1 rounded-full shadow-sm">
        ID: #<%= @block.id.to_s.rjust(3, '0') %>
      </span>
    </div>

    <div class="p-6">
      <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-4 gap-y-6">
        <div class="sm:col-span-1">
          <dt class="text-sm font-medium text-gray-500">Quantidade de Andares</dt>
          <dd class="mt-1 text-lg font-semibold text-gray-900"><%= @block.floors_count %></dd>
        </div>
        <div class="sm:col-span-1">
          <dt class="text-sm font-medium text-gray-500">Apartamentos por Andar</dt>
          <dd class="mt-1 text-lg font-semibold text-gray-900"><%= @block.apartments_per_floor %></dd>
        </div>
        
        <div class="sm:col-span-2 bg-gray-50 p-4 rounded-xl border border-gray-200 mt-2 flex items-center justify-between">
          <div>
            <dt class="text-sm font-bold text-gray-700 mb-1">Capacidade Total</dt>
            <dd class="text-gray-500 text-sm">Total de unidades nesta torre</dd>
          </div>
          <div class="text-3xl font-black text-blue-600">
            <%= @block.floors_count * @block.apartments_per_floor %> <span class="text-sm font-bold text-gray-400">apts</span>
          </div>
        </div>
      </dl>
    </div>

    <div class="bg-gray-50 px-6 py-4 border-t border-gray-200 flex flex-col sm:flex-row justify-between items-center gap-4">
      <%= link_to "← Voltar para Tabela", blocks_path, class: "text-gray-500 hover:text-blue-600 font-semibold transition-colors text-sm" %>

      <div class="flex space-x-3 w-full sm:w-auto">
        <%= link_to "Editar", edit_block_path(@block), class: "flex-1 sm:flex-none text-center px-6 py-2 bg-white border border-gray-300 rounded-lg shadow-sm text-sm font-bold text-gray-700 hover:bg-gray-50 transition-colors" %>
        
        <%= link_to "Excluir", @block, data: { turbo_method: :delete, turbo_confirm: "ATENÇÃO: Tem certeza que deseja excluir esta torre e todos os apartamentos dentro dela?" }, class: "flex-1 sm:flex-none text-center px-6 py-2 bg-red-600 border border-transparent rounded-lg shadow-sm text-sm font-bold text-white hover:bg-red-700 transition-colors" %>
      </div>
    </div>
    
  </div>
</div>
