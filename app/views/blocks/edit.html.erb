<% provide(:title, "Editar Bloco | Condomínio Dunnas") %>

<div class="max-w-xl mx-auto mt-10">
  <div class="bg-white p-8 rounded-2xl shadow-lg border border-gray-100">
    <div class="mb-8 border-b pb-4">
      <h1 class="text-3xl font-extrabold text-gray-900">Editar Torre / Bloco</h1>
      <p class="text-gray-500 mt-2 text-sm">Atualize as informações estruturais deste bloco.</p>
    </div>

    <%= render "form", block: @block %>
  </div>

  <div class="mt-8 text-center mb-10 text-sm">
    <%= link_to "← Voltar para Gestão de Blocos", blocks_path, class: "text-gray-500 hover:text-blue-600 font-semibold transition-colors" %>
  </div>
</div>
